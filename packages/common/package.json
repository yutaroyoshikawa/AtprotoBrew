{
	"name": "common",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "expo start -c",
		"android": "expo start -c --android",
		"ios": "expo start -c --ios",
		"web": "expo start -c --web",
		"clean": "rm -rf .expo node_modules",
		"lingui:exact": "lingui extract",
		"libgui:build": "lingui compile"
	},
	"exports": {
		"./components/*": {
			"import": "./src/components/*.tsx"
		},
		"./lib/*": {
			"import": "./src/components/*.ts"
		}
	},
	"dependencies": {
		"@lingui/react": "^5.9.5",
		"@react-navigation/native": "^7.0.0",
		"@rn-primitives/portal": "~1.4.0",
		"@rn-primitives/slot": "^1.4.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"expo": "~55.0.9",
		"expo-constants": "~55.0.9",
		"expo-linking": "~55.0.9",
		"expo-router": "~55.0.8",
		"expo-splash-screen": "~55.0.13",
		"expo-status-bar": "~55.0.4",
		"expo-system-ui": "~55.0.11",
		"lucide-react-native": "^0.545.0",
		"nativewind": "^4.2.3",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.2",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-svg": "15.15.3",
		"react-native-web": "^0.21.0",
		"react-native-worklets": "0.7.2",
		"solito": "^5.0.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@babel/core": "^7.26.0",
		"@lingui/babel-plugin-lingui-macro": "^5.9.5",
		"@lingui/vite-plugin": "^5.9.5",
		"@types/react": "~19.2.10",
		"typescript": "^6.0.3"
	},
	"private": true
